# Supabase Cloud — obten estos valores en:
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Anon (publishable) key — requerido para que el backend use clientes
# user-scoped y RLS aplique como defensa-en-profundidad.
SUPABASE_ANON_KEY=eyJhbGciOi...

# Solo necesario para proyectos legacy con HS256.
# Proyectos modernos verifican JWTs contra el JWKS publico — dejar vacio.
SUPABASE_JWT_SECRET=

# Database connection — Settings -> Database -> Connection string -> URI
# Reemplaza [YOUR-PASSWORD] con tu password de DB
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]

# DeepL Free API key — opcional. Si no se setea, el lookup retorna translation=null
# y el popup muestra "(sin traducción — DeepL no configurada)".
# Crear key gratis en https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Redis — opcional. Activa modo multi-worker / multi-pod.
# Si no está set: stampede lock + cache layer caen a in-memory (single-process).
# Si está set: distributed lock via SET NX EX + L2 cache compartido entre pods.
# Ver docs/architecture/scaling-migration.md
REDIS_URL=

# Background-warmer ownership en multi-pod. Default true (single-pod ok).
# En multi-pod, set true en exactamente UN pod (el "leader") y false en el resto.
# Sin esto, N pods × N tasks hammering Gutendex en el mismo schedule.
WARMER_ENABLED=true

# ==============================================================================
# Card enrichment (LLM)
# ==============================================================================
# Background worker que enriquece cards capturadas con info gramatical
# (POS, tense, phrasal, CEFR, register, etc.) usando un LLM.
#
# Si TODAS las keys del provider se agotan, el card queda con enrichment=NULL
# y el siguiente cron lo retry-ea — el flow de captura/study NUNCA se bloquea
# por fallos del LLM (graceful degradation).
#
# Multi-key: separa con coma para fan-out entre cuentas (extiende free tier).

# Provider activo. Cambiar a "groq" para usar Groq Llama (más rápido, paid).
ENRICHMENT_PROVIDER=gemini

# Gemini Flash — free tier 15k req/día. https://aistudio.google.com/apikey
# Acepta varias keys separadas por coma para multiplicar quota.
GEMINI_API_KEYS=

# Groq Llama — ultra rápido (~100ms). https://console.groq.com/keys
# Acepta varias keys separadas por coma.
GROQ_API_KEYS=

# Cron del worker (minutos). 5 = balance entre freshness y costo.
ENRICHMENT_INTERVAL_MIN=5
# Cap de cards por tick. Calibrado para Gemini Flash free tier
# (15 req/min/key) — 5 cards × 1 req cabe sin quemar quota incluso con
# una sola key. Subir si tienes 4+ keys y quieres drenar backlogs.
ENRICHMENT_BATCH_SIZE=5
