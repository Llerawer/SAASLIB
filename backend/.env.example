# Supabase Cloud — obten estos valores en:
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Anon (publishable) key — requerido para que el backend use clientes
# user-scoped y RLS aplique como defensa-en-profundidad.
SUPABASE_ANON_KEY=eyJhbGciOi...

# Solo necesario para proyectos legacy con HS256.
# Proyectos modernos verifican JWTs contra el JWKS publico — dejar vacio.
SUPABASE_JWT_SECRET=

# Database connection — Settings -> Database -> Connection string -> URI
# Reemplaza [YOUR-PASSWORD] con tu password de DB
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]

# DeepL Free API key — opcional. Si no se setea, el lookup retorna translation=null
# y el popup muestra "(sin traducción — DeepL no configurada)".
# Crear key gratis en https://www.deepl.com/pro-api
DEEPL_API_KEY=

# Redis — opcional. Activa modo multi-worker / multi-pod.
# Si no está set: stampede lock + cache layer caen a in-memory (single-process).
# Si está set: distributed lock via SET NX EX + L2 cache compartido entre pods.
# Ver docs/architecture/scaling-migration.md
REDIS_URL=
