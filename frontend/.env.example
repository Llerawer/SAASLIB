# Supabase Cloud — obten estos valores en:
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Backend FastAPI — leave EMPTY to use the Next.js rewrite proxy
# (recommended). Single-origin design avoids mixed-content + CORS issues
# on Cloudflare tunnels, LAN access, and production. To override, set an
# absolute URL: http://localhost:8000
NEXT_PUBLIC_API_URL=

# Where Next.js rewrites should forward /api/* requests. Defaults to
# http://localhost:8100 if unset. Set this in production to your
# deployed backend's URL (e.g., https://api.yourdomain.com).
BACKEND_PROXY_URL=http://localhost:8100
